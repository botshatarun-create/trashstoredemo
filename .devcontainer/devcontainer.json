{
    "name": "Trash Store Dev Environment",
    "image": "mcr.microsoft.com/devcontainers/java:17",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:1": {
            "installZsh": true,
            "configureZshAsDefaultShell": true,
            "upgradePackages": true
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vmware.vscode-spring-boot",
                "vscjava.vscode-spring-initializr",
                "vscjava.vscode-spring-boot-dashboard"
            ]
        }
    },
    "forwardPorts": [
        8080
    ],
    "portsAttributes": {
        "8080": {
            "label": "Trash Store Web App",
            "onAutoForward": "openBrowser",
            "visibility": "public"
        }
    },
    "postCreateCommand": "sed -i 's/\\r$//' mvnw && chmod +x mvnw && ./mvnw -DskipTests clean install || mvn -DskipTests clean install",
    "postStartCommand": "./mvnw spring-boot:run || mvn spring-boot:run",
    "remoteUser": "vscode"
}